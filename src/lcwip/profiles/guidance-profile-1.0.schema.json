{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.banes-satn.example/lcwip/guidance-profile-1.0.schema.json",
  "title": "LCWIP Guidance Profile",
  "description": "Versioned requirements used to evaluate an LCWIP release. Unknown evidence is never compliance.",
  "type": "object",
  "required": ["schema_version", "profile_id", "issuer", "document", "version", "effective_date", "applicability", "requirements"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "profile_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "issuer": {"type": "string", "minLength": 1, "pattern": "\\S"},
    "document": {"type": "string", "minLength": 1, "pattern": "\\S"},
    "version": {"type": "string", "minLength": 1, "pattern": "\\S"},
    "effective_date": {"type": "string", "format": "date"},
    "applicability": {"type": "string", "minLength": 1, "pattern": "\\S"},
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["requirement_id", "obligation", "expected_artifacts"],
        "properties": {
          "schema_version": {"const": "1.0"},
          "requirement_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
          "obligation": {"enum": ["mandatory", "recommended", "locally-selected"]},
          "expected_artifacts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "pattern": "\\S"}},
          "description": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
